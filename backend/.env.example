GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,qwen/qwen3-32b,llama3-8b-8192
DATABASE_URL=postgresql+asyncpg://db_user:db_password@localhost:5432/db_name
FAISS_PERSIST_DIR=./faiss_store
FAISS_INDEX_PATH=./faiss_store
UPLOAD_DIR=./uploads
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
GEMINI_API_KEY=
VOICE_ENABLED=false
JWT_SECRET_KEY=your_jwt_secret_key_here
SECRET_KEY=your_jwt_secret_key_here
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
PORT=8002

# ── Security Settings ──────────────────────────────────────────────────────────
# Set to true ONLY when running behind a trusted reverse proxy (nginx, AWS ALB).
# This enables X-Forwarded-For trust for real IP extraction in the rate limiter.
# If not behind a proxy, leave as false to prevent IP spoofing attacks.
TRUSTED_PROXY=false

# Set to true to enable /docs, /redoc, /openapi.json endpoints (development only).
# MUST be false in production to prevent API enumeration by attackers.
ENABLE_DOCS=false

# Upload rate limit: max resume uploads per user per hour.
RATE_LIMIT_UPLOAD_LIMIT=10
RATE_LIMIT_UPLOAD_WINDOW=3600
